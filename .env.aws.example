# Used by docker-compose.aws.yml. Copy to .env.aws and replace this value.
POSTGRES_PASSWORD=replace-with-a-long-random-password

# Optional integrations
OPENAI_API_KEY=
ABUSEIPDB_API_KEY=
NID_ENABLE_GEOIP=0
NID_ALERT_WEBHOOK=
NID_DISCORD_WEBHOOK=
NID_EMAIL_TO=
NID_EMAIL_FROM=nid-alerts@localhost
NID_SMTP_HOST=
NID_SMTP_PORT=587
NID_SMTP_TLS=1
NID_SMTP_USERNAME=
NID_SMTP_PASSWORD=
NID_TELEGRAM_BOT_TOKEN=
NID_TELEGRAM_CHAT_ID=

# Detection defaults
NID_WINDOW_SECONDS=0.5
NID_PACKET_LIMIT=500
NID_MIN_PACKETS=10
NID_ALERT_THRESHOLD=0.75
NID_FULL_SHAP_LIVE=0
NID_AUTO_RESPONSE=0
