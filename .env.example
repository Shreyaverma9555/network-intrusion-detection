# Deployment contract
DATABASE_URL=
SUPABASE_URL=
SUPABASE_KEY=
SECRET_KEY=change-this-random-application-secret
JWT_SECRET=change-this-independent-jwt-secret
MODEL_PATH=ml/model.pkl
API_URL=http://localhost:8000
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=
POSTGRES_PASSWORD=change-this-database-password
NID_SENSOR_API_KEY=change-this-independent-sensor-secret
CORS_ORIGINS=http://localhost:5173
ALLOWED_HOSTS=localhost,127.0.0.1
RATE_LIMIT_PER_MINUTE=120
FORCE_HTTPS=0

# Optional AI explanation
OPENAI_API_KEY=
NID_LLM_MODEL=gpt-4.1-mini

# Threat intelligence and attack map
NID_ENABLE_GEOIP=0
NID_ENABLE_RDAP=0

# Optional webhook and email alerts
NID_ALERT_WEBHOOK=
NID_DISCORD_WEBHOOK=
NID_EMAIL_TO=
NID_EMAIL_FROM=nid-alerts@localhost
NID_SMTP_HOST=
NID_SMTP_PORT=587
NID_SMTP_TLS=1
NID_SMTP_USERNAME=
NID_SMTP_PASSWORD=
NID_TELEGRAM_BOT_TOKEN=
NID_TELEGRAM_CHAT_ID=
NID_ALERT_COOLDOWN_SECONDS=300
NID_ALERT_MIN_SEVERITY=High
NID_ALERT_THRESHOLD=0.75
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_TO=

# PostgreSQL is the primary persistent event and analytics database
NID_MONGODB_URI=
NID_POSTGRES_DSN=postgresql://nid_user:password@localhost:5432/nid

# Real-time automatic response policy
# Blocking remains disabled until --auto-block, --auto-response, or a dashboard checkbox is used.
NID_BLOCK_MIN_CONFIDENCE=0.90
NID_BLOCK_MIN_THREAT_SCORE=75
NID_AUTO_RESPONSE=0
NID_MIN_PACKETS=10
NID_WINDOW_SECONDS=0.5
NID_LOOP_DELAY=0.05
NID_DASHBOARD_REFRESH_DELAY=0.1
NID_PACKET_LIMIT=500
NID_FULL_SHAP_LIVE=0
NID_DASHBOARD_USERNAME=admin
NID_DASHBOARD_PASSWORD=
NID_DASHBOARD_PASSWORD_SHA256=
NID_DASHBOARD_ROLE=admin
NID_API_USERNAME=admin
NID_API_PASSWORD=
NID_API_PASSWORD_SHA256=
NID_API_ROLE=admin
NID_API_USERS_JSON=
NID_JWT_SECRET=change-this-long-random-secret
NID_JWT_MINUTES=60
NID_API_CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# Split cloud deployment: the sensor runs beside the monitored network.
NID_API_URL=http://127.0.0.1:8000
NID_SENSOR_INTERFACE=
NID_MODEL_PATH=models/sample_ensemble.joblib
NID_SERVER_ALERTS=0
